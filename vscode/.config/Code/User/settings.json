{
  "window.zoomLevel": 2,
  "workbench.colorTheme": "GitHub Dark Default",
  "workbench.iconTheme": "catppuccin-latte",
  "workbench.colorCustomizations": {
    "[GitHub Dark Default]": {
      // Terminal
      "terminal.background": "#010409",
      "terminal.foreground": "#e6edf3",
      "terminalCursor.foreground": "#e6edf3",
      "terminal.selectionBackground": "#3b5070",
      "terminal.ansiBlack": "#484f58",
      "terminal.ansiRed": "#ff7b72",
      "terminal.ansiGreen": "#3fb950",
      "terminal.ansiYellow": "#d29922",
      "terminal.ansiBlue": "#58a6ff",
      "terminal.ansiMagenta": "#bc8cff",
      "terminal.ansiCyan": "#39c5cf",
      "terminal.ansiWhite": "#b1bac4",
      "terminal.ansiBrightBlack": "#6e7681",
      "terminal.ansiBrightRed": "#ffa198",
      "terminal.ansiBrightGreen": "#56d364",
      "terminal.ansiBrightYellow": "#e3b341",
      "terminal.ansiBrightBlue": "#79c0ff",
      "terminal.ansiBrightMagenta": "#d2a8ff",
      "terminal.ansiBrightCyan": "#56d4dd",
      "terminal.ansiBrightWhite": "#ffffff",

      // Popup de sugestões (cores do Oscura Dusk)
      "editorSuggestWidget.background": "#161616",
      "editorSuggestWidget.border": "#282828",
      "editorSuggestWidget.foreground": "#E6E6E6",
      "editorSuggestWidget.highlightForeground": "#FFF",
      "editorSuggestWidget.selectedBackground": "#232323",
      "editorSuggestWidget.selectedForeground": "#E6E6E6",

      // Hover tooltip (cores do Oscura Dusk)
      "editorHoverWidget.background": "#161616",
      "editorHoverWidget.border": "#282828",
      "editorHoverWidget.foreground": "#E6E6E6",

      // Lista de seleção no popup
      "list.activeSelectionBackground": "#232323",
      "list.activeSelectionForeground": "#E6E6E6",
      "list.hoverBackground": "#FFFFFF08",
      "list.highlightForeground": "#FFF",

      // Git gutter
      "editorGutter.modifiedBackground": "#FFA500",
    },
  },
  "gitlens.ai.model": "gitkraken",
  "gitlens.ai.gitkraken.model": "gemini:gemini-2.5-flash",
  "diffEditor.ignoreTrimWhitespace": false,
  "redhat.telemetry.enabled": true,
  "settingsSync.ignoredExtensions": [],
  "git.confirmSync": false,
  "[javascriptreact]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
  },

  // Fonte e cursor
  "editor.fontFamily": "'JetBrains Mono NL', 'Droid Sans Mono', 'monospace'",
  "editor.fontSize": 14,
  "editor.fontWeight": "400",
  "editor.lineHeight": 1.6,
  "editor.cursorBlinking": "smooth",
  "editor.cursorWidth": 3,
  "editor.tabSize": 2,
  "editor.insertSpaces": true,
  "editor.detectIndentation": false,
  "editor.cursorSmoothCaretAnimation": "on",
  "editor.smoothScrolling": true,
  "workbench.list.smoothScrolling": true,

  // Fonte do terminal
  "terminal.integrated.fontFamily": "JetBrains Mono NL",
  "terminal.integrated.fontSize": 14,
  "terminal.integrated.fontWeight": "400",
  "terminal.integrated.cursorStyle": "underline",

  // UI
  "editor.minimap.enabled": true,
  "claudeCode.preferredLocation": "panel",
  "editor.minimap.renderCharacters": false,

  // Sugestões
  "editor.suggestSelection": "first",
  "editor.parameterHints.enabled": false,
  "editor.acceptSuggestionOnCommitCharacter": false,
  "javascript.suggest.autoImports": true,
  "typescript.suggest.autoImports": true,
  "typescript.preferences.preferTypeOnlyAutoImports": true,

  // Identificação de erros
  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": "explicit",
  },
  "eslint.validate": ["javascript", "javascriptreact", "graphql"],
  "editor.renderLineHighlight": "gutter",
  "window.titleBarStyle": "custom",
  "tabnine.experimentalAutoImports": true,
}
